{
  "platforms": [
    {
      "id": "auto",
      "label": "Auto (detect editor)",
      "description": "Use the model for whichever editor you run Loom in (Cursor, Claude Code, or Hermes)"
    },
    {
      "id": "cursor",
      "label": "Cursor",
      "description": "Cursor IDE subagents (.cursor/agents frontmatter)"
    },
    {
      "id": "claude",
      "label": "Claude Code",
      "description": "Claude Code subagents (~/.claude/agents frontmatter)"
    },
    {
      "id": "hermes",
      "label": "Hermes",
      "description": "Hermes Agent sessions (hermes -m / ~/.hermes/config.yaml)"
    }
  ],
  "defaults": {
    "cursor": "composer-2.5",
    "claude": "sonnet",
    "hermes": "inherit"
  },
  "models": {
    "cursor": [
      {
        "id": "inherit",
        "label": "Inherit (editor default)",
        "description": "Same model as your Cursor chat session"
      },
      {
        "id": "composer-2.5",
        "label": "Composer 2.5",
        "description": "Cursor-native agent model — recommended default",
        "default": true
      },
      {
        "id": "claude-sonnet-5-thinking-medium",
        "label": "Sonnet 5",
        "description": "Balanced Anthropic model"
      },
      {
        "id": "claude-opus-4-8-thinking-medium",
        "label": "Opus 4.8",
        "description": "Strongest reasoning"
      },
      {
        "id": "composer-2.5-fast",
        "label": "Composer 2.5 Fast",
        "description": "Lighter Composer for quick tasks"
      },
      {
        "id": "gpt-5.3-codex",
        "label": "GPT 5.3 Codex",
        "description": "OpenAI coding model"
      },
      {
        "id": "gemini-3.5-flash",
        "label": "Gemini 3.5 Flash",
        "description": "Fast Google model"
      }
    ],
    "claude": [
      {
        "id": "inherit",
        "label": "Inherit (session default)",
        "description": "Same model as the main Claude Code conversation"
      },
      {
        "id": "sonnet",
        "label": "Sonnet",
        "description": "Latest Sonnet — recommended default",
        "default": true
      },
      {
        "id": "opus",
        "label": "Opus",
        "description": "Latest Opus for complex reasoning"
      },
      {
        "id": "haiku",
        "label": "Haiku",
        "description": "Fast and efficient"
      },
      {
        "id": "fable",
        "label": "Fable",
        "description": "Long-running hard tasks"
      },
      {
        "id": "claude-sonnet-5",
        "label": "Sonnet 5 (full ID)",
        "description": "Pin Sonnet 5 explicitly"
      },
      {
        "id": "claude-opus-4-8",
        "label": "Opus 4.8 (full ID)",
        "description": "Pin Opus 4.8 explicitly"
      }
    ],
    "hermes": [
      {
        "id": "inherit",
        "label": "Inherit (hermes config default)",
        "description": "Use model.default from ~/.hermes/config.yaml",
        "default": true
      },
      {
        "id": "anthropic/claude-sonnet-4.6",
        "label": "Claude Sonnet 4.6",
        "description": "OpenRouter / Nous — needs Anthropic-capable provider"
      },
      {
        "id": "anthropic/claude-opus-4.8",
        "label": "Claude Opus 4.8",
        "description": "OpenRouter / Nous — needs Anthropic-capable provider"
      },
      {
        "id": "anthropic/claude-haiku-4.5",
        "label": "Claude Haiku 4.5",
        "description": "Fast Anthropic model"
      },
      {
        "id": "openai/gpt-5.5",
        "label": "GPT 5.5",
        "description": "OpenRouter / Nous — needs OpenAI-capable provider"
      },
      {
        "id": "google/gemini-3.5-flash",
        "label": "Gemini 3.5 Flash",
        "description": "Fast Google model"
      },
      {
        "id": "deepseek/deepseek-v4-flash",
        "label": "DeepSeek V4 Flash",
        "description": "Fast DeepSeek model"
      }
    ]
  }
}
